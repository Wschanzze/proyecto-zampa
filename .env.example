# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Supabase (if using database/auth)
NEXT_PUBLIC_SUPABASE_URL=https://dummy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummykey.updateyourkey.here

# API Keys (optional - for future features)
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=enter-your-value-here

# Advertising (optional)
NEXT_PUBLIC_ADSENSE_ID=your-adsense-id-here

# Third-party APIs (optional)
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# Payment (optional - if adding payment features)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
